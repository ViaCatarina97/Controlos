rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net (vulnerability default/allow-all defense)
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Restaurants database collection & sub-structures
    match /restaurants/{restaurantId} {
      allow list: if true;
      allow get, create, update: if isValidId(restaurantId);

      match /employees/{employeeId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(employeeId);
      }

      match /staffing_table/{staffId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(staffId);
      }

      match /history/{historyDate} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(historyDate);
      }

      match /schedules/{scheduleDate} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(scheduleDate);
      }

      match /deliveries/{deliveryId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(deliveryId);
      }

      match /credits/{creditId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(creditId);
      }

      match /monthly_ops/{monthId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(monthId);
      }

      match /cofre_counts/{countId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(countId);
      }

      match /deposits/{depositId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(depositId);
      }

      match /caixas_surpresa/{caixaSurpresaId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(caixaSurpresaId);
      }

      match /prosegur_deposits/{prosegurDepositId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(prosegurDepositId);
      }

      match /prosegur_weekly_deposits/{weeklyId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(weeklyId);
      }

      match /prosegur_coin_movements/{coinId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(coinId);
      }

      match /manager_tasks/{taskId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(taskId);
      }

      match /manager_checklists/{checklistId} {
        allow list: if isValidId(restaurantId);
        allow get, create, update, delete: if isValidId(restaurantId) && isValidId(checklistId);
      }
    }
  }
}
